# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Public base URL of the site. Used to build admin links in Telegram notifications.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase project URL and keys (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard password (used at /admin/login)
ADMIN_PASSWORD=

# Email confirmations through Resend (optional in local development).
# ORDER_FROM_EMAIL example: China Delight <orders@yourdomain.com>
RESEND_API_KEY=
ORDER_FROM_EMAIL=

# Telegram admin notifications for new orders (optional).
# Create a bot with BotFather and set the chat ID that should receive admin alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Sheets live sales sync (optional).
# Share the target spreadsheet with GOOGLE_SERVICE_ACCOUNT_EMAIL as an editor.
# Set GOOGLE_SHEETS_ENABLED=false to explicitly disable sync.
GOOGLE_SHEETS_ENABLED=true
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_ORDERS_SHEET_NAME=Orders
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Android tablet native printer app.
# Set the real restaurant-only code in Vercel and enter the same code in the tablet app.
ANDROID_PRINT_BRIDGE_CODE=

# Local Epson TM-m30 / M335A kitchen printer (ESC/POS over TCP, port 9100).
# Used by /api/admin/print-ticket for manual and auto kitchen printing.
# Defaults to 192.168.1.172:9100 if left blank.
PRINTER_IP=192.168.1.172
PRINTER_PORT=9100

# Sales tax rate applied at checkout (Connecticut prepared meals = 0.0735 = 7.35%)
NEXT_PUBLIC_TAX_RATE=0.0735

# Processing fee rate applied at checkout (0.06 = 6%)
NEXT_PUBLIC_PROCESSING_FEE_RATE=0.06
