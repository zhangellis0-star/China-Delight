# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Public base URL of the site. Used to build Stripe success/cancel redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase project URL and keys (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe API keys (Dashboard -> Developers -> API keys). Use test keys (sk_test_/pk_test_) for development.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret (whsec_...).
# Local dev: printed by `stripe listen --forward-to localhost:3000/api/stripe/webhook`.
# Production: from the webhook endpoint you create in the Stripe Dashboard.
STRIPE_WEBHOOK_SECRET=

# Admin dashboard password (used at /admin/login)
ADMIN_PASSWORD=

# Sales tax rate applied at checkout (e.g. 0.0635 = 6.35%)
NEXT_PUBLIC_TAX_RATE=0.0635
