# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Public base URL of the site. Used to build Stripe success/cancel redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase project URL and keys (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe API keys (Dashboard -> Developers -> API keys). Use test keys (sk_test_/pk_test_) for development.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret (whsec_...).
# Local dev: printed by `stripe listen --forward-to localhost:3000/api/stripe/webhook`.
# Production: from the webhook endpoint you create in the Stripe Dashboard.
STRIPE_WEBHOOK_SECRET=

# Admin dashboard password (used at /admin/login)
ADMIN_PASSWORD=

# Email confirmations through Resend (optional in local development).
# ORDER_FROM_EMAIL example: China Delight <orders@yourdomain.com>
RESEND_API_KEY=
ORDER_FROM_EMAIL=

# Sales tax rate applied at checkout (Connecticut prepared meals = 0.0735 = 7.35%)
NEXT_PUBLIC_TAX_RATE=0.0735

# Processing fee rate applied at checkout (0.06 = 6%)
NEXT_PUBLIC_PROCESSING_FEE_RATE=0.06

# Twilio SMS for phone verification (optional).
# Leave blank for local development: verification runs in dev mode and never sends a real text.
# Set all three in production to send real SMS codes.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
